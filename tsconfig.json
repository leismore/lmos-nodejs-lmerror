{
  "compilerOptions":
  {
    "lib":                          ["ES2024"],
    "target":                        "ES2024",
    "module":                        "nodenext",
    "moduleResolution":              "nodenext",
    "strict":                        true,
    "resolveJsonModule":             true,
    "declaration":                   true,
    "allowJs":                       false,
    "outDir":                        "dist",
    "types":                        ["node"]
  },
  "include":            ["src/**/*", "test/**/*"]
}
